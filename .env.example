# ============ Domínio ============
# Um único domínio concentra tudo (landing, app, admin e API por /api),
# roteado por caminho no Caddy — ver infra/caddy/Caddyfile.
# Sempre hostname puro, SEM esquema (nada de "http://" ou "https://" aqui).
# Dev local (default): Caddy emite certificado interno automaticamente para *.localhost.
DOMAIN=localhost
# Produção: comente a linha acima e descomente a de baixo (DNS apontando pro VPS).
# DOMAIN=couthealth.com.br

# ============ Postgres ============
POSTGRES_USER=couthealth
POSTGRES_PASSWORD=changeme
POSTGRES_DB=couthealth
DATABASE_URL=postgresql://couthealth:changeme@postgres:5432/couthealth?schema=public

# ============ Redis ============
REDIS_URL=redis://redis:6379

# ============ MinIO ============
MINIO_ROOT_USER=couthealth
MINIO_ROOT_PASSWORD=changeme123
MINIO_BUCKET=couthealth
MINIO_ENDPOINT=minio
MINIO_PORT=9000

# ============ Auth ============
JWT_SECRET=changeme-generate-a-long-random-secret
JWT_REFRESH_SECRET=changeme-generate-another-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============ Pagamento ============
PAYMENT_PROVIDER=mock
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# ============ API ============
API_PORT=3000
NODE_ENV=development
# Vazio = CORS liberado (útil em dev). Em produção, restrinja aos domínios reais.
CORS_ORIGINS=
# Webhook do Asaas (header asaas-access-token) — sem isso, o endpoint recusa qualquer chamada.
ASAAS_WEBHOOK_TOKEN=

# ============ Stitch (NUNCA commitar valor real) ============
STITCH_API_KEY=
