{
  "name": "couthealth",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:landing": "npm run dev -w apps/landing",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run start:dev -w apps/api",
    "dev:worker": "npm run dev -w apps/worker",
    "build": "npm run build -w apps/landing && npm run build -w apps/web && npm run build -w apps/api && npm run build -w apps/worker"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "@nestjs/core@10.4.22": true,
    "argon2@0.44.0": true,
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "msgpackr-extract@3.0.4": true,
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "prisma@5.22.0": true,
    "sharp@0.32.6": true
  }
}
