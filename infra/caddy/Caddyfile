{
	# Local dev: certificados internos autoassinados para *.localhost.
	local_certs
	# Produção (VPS com aaPanel): aaPanel/Nginx termina TLS e faz proxy reverso
	# para o Caddy em 127.0.0.1:8080 (só HTTP). Sem isso, o Caddy tenta emitir
	# certificado próprio e falha porque não tem mais acesso direto à porta 443.
	auto_https off
}

{$DOMAIN:localhost} {
	reverse_proxy landing:3100
}

{$APP_DOMAIN:app.localhost} {
	reverse_proxy web:80
}

{$API_DOMAIN:api.localhost} {
	reverse_proxy api:3000
}
